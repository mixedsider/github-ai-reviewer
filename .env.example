# ============================================================
# GitHub AI 자동 코드 리뷰어 환경 변수 예시
# 이 파일을 복사하여 .env 로 이름 변경 후 값을 채우세요.
# .env 파일은 절대 git에 커밋하지 마세요.
# ============================================================

# ----------------------------------------------------------
# [필수] AI 제공자 선택
# 사용할 AI 제공자를 선택하세요: anthropic / openai / local
# ----------------------------------------------------------
AI_PROVIDER=anthropic

# ----------------------------------------------------------
# [AI 제공자별 설정] 사용하는 제공자의 값만 채우세요
# ----------------------------------------------------------

# Anthropic (Claude) 사용 시
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (GPT) 사용 시
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o  # 선택사항, 기본값: gpt-4o

# 로컬 모델 (Ollama / LM Studio) 사용 시
# self-hosted GitHub Actions runner 환경에서만 동작합니다
LOCAL_MODEL_URL=http://localhost:11434   # Ollama 기본 포트
# LOCAL_MODEL_URL=http://localhost:1234  # LM Studio 기본 포트
LOCAL_MODEL_NAME=llama3

# ----------------------------------------------------------
# [GitHub Actions 자동 주입] 아래 값은 워크플로우에서 자동으로 설정됩니다
# 로컬 테스트 시에만 직접 채우세요
# ----------------------------------------------------------
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPOSITORY=your-org/your-repo  # 예: myorg/myproject
PR_NUMBER=1                            # PR 번호 (PR 리뷰 테스트 시)
ISSUE_NUMBER=1                         # 이슈 번호 (이슈 응답 테스트 시)
